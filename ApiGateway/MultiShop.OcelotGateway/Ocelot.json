{
  "Routes": [
    // catalog Microservice
    {
      // UpstreamPathTemplate: Request'in geldiği yer. burada catalog microservice'inden geldiğini belirttik
      // UpstreamHttpMethod: hangi metodlara izin veriyoruz
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "UpstreamPathTemplate": "/services/catalog/{everything}",
      "UpstreamScheme": "http",

      //DownstreamPathTemplate: hangi endpointlere istek yapılacak.api'den sonra ne gelirse gelsin hepsini UpstreamPathTemplat^'de karşılıyoruz
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          // catalog için port numaram 7070
          "Port": 7070
        }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "OcelotAuthenticationScheme",
        "AllowedScopes": [ "CatalogFullPermission" ]
      }
    },
    //Discount Microservice
    {
      "DownstreamPathTemplate": "/api/{everything}",
