@using MultiShop.DtoLayer.CommentDtos
@model UpdateCommentDto
@{
    ViewData["Title"] = "UpdateComment";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Update Comment</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <input type ="hidden" asp-for="UserCommentId" />
                        <input type="hidden" asp-for="ProductId" />
                        <label>User Name Surname</label>
                        <input type="text" class="form-control" asp-for="NameSurname">
                        <br />
                        <label>User Image</label>
                        <input type="text" class="form-control" asp-for="ImageUrl">
                        <br />
                        <label>Email Address</label>
                        <input type="text" class="form-control" asp-for="Email">
                        <br />
                        <label>Comment</label>
                        <textarea class="form-control" asp-for="CommentDetail" rows="3"></textarea>
                        <br />
                        <label>User Rating</label>
                        <input type="text" class="form-control" asp-for="Rating">
                        <br />
                        <label>Comment Date</label>
                        <input type="date" class="form-control" asp-for="CreatedDate">
                        <br />
                        <label>Status</label>
                        <input type="text" class="form-control" asp-for="Status">
                        <br />

                        <button class="btn btn-primary">Update Comment</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>



