
@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
@await Component.InvokeAsync("_AdminLayoutHeadComponentPartial")

<body class="sidebar-mini">
    <div class="wrapper">

        @await Component.InvokeAsync("_AdminLayoutHeaderComponentPartial")

        @await Component.InvokeAsync("_AdminLayoutSideBarComponentPartial")

        <div class="content-wrapper">
            @await Component.InvokeAsync("_AdminLayoutMainSectionViewBagComponentPartial")


            @RenderBody()
        </div>
        <!-- content-wrapper -->
        <!-- Main Footer -->
        <footer class="main-footer dark-bg">
            <div class="pull-right hidden-xs"> Version 1.0</div>
            Copyright &copy; 2017 Yourdomian. All rights reserved.
        </footer>
    </div>
    <!-- wrapper -->
    <!-- jQuery -->
    <script src="~/OvioAdmin/html/dist/js/jquery.min.js"></script>
    <script src="~/OvioAdmin/html/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/OvioAdmin/html/dist/js/ovio.js"></script>
</body>
</html>