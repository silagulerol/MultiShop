@model CreateBrandDto
@{
    ViewData["Title"] = "CreateBrand";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Add a New Brand</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <label>About Name</label>
                        <input type="text" class="form-control" asp-for="BrandName">
                        <br />
                        <label>Image Url</label>
                        <input type="text" class="form-control" asp-for="ImageUrl">
                        <br />
                        <button class="btn btn-primary">Add Brand</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

