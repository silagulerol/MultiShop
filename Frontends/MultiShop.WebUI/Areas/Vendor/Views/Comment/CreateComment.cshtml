@using MultiShop.DtoLayer.CommentDtos
@model CreateCommentDto
@{
    ViewData["Title"] = "CreateComment";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Add a New Comment</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <label>User</label>
                        <input type="text" class="form-control" asp-for="NameSurname">
                        <br />
                        <label>Image Url</label>
                        <input type="text" class="form-control" asp-for="ImageUrl">
                        <br />
                        <label>Email</label>
                        <input type="text" class="form-control" asp-for="Email">
                        <br />
                        <label>Comment</label>
                        <input type="text" class="form-control" asp-for="CommentDetail">
                        <br />
                        <label>Rating</label>
                        <input type="text" class="form-control" asp-for="Rating">
                        <br />
                        <label>Status</label>
                        <input type="text" class="form-control" asp-for="Status">
                        <br />
                        <label>ProductId</label>
                        <input type="text" class="form-control" asp-for="ProductId">
                        <br />

                        <button class="btn btn-primary">Add Comment</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

